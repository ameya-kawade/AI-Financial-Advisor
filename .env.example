# AI Financial Advisor — Environment Variables
# Copy this file to .env and fill in your values.

# LLM Provider
# Waterfall order when MODEL_PROVIDER=auto (recommended):
#   Tier 1 → Gemini cloud via Ollama  (gemini-3-flash-preview:cloud)
#   Tier 2 → Google Gemini REST API   (requires GOOGLE_API_KEY)
#   Tier 3 → Local Ollama model       (OLLAMA_MODEL)
#   Final  → Deterministic rule-based advice
#
# Options: auto | gemini_ollama | gemini | ollama
MODEL_PROVIDER=auto

# Google Gemini API (Tier 2 in auto)
GOOGLE_API_KEY=your_gemini_api_key_here

# Ollama Configuration (Tier 1 & Tier 3)
# Ensure Ollama is running: `ollama serve`
#
# Tier 1 — Gemini cloud via Ollama (routes to Google Cloud):
#   Pull with: ollama pull gemini-3-flash-preview:cloud
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_GEMINI_MODEL=gemini-3-flash-preview:cloud
OLLAMA_GEMINI_TIMEOUT=60
#
# Tier 3 — Local Ollama model:
#   Pull with: ollama pull qcwind/qwen2.5-7B-instruct-Q4_K_M:latest
OLLAMA_MODEL=qcwind/qwen2.5-7B-instruct-Q4_K_M:latest
OLLAMA_TIMEOUT=300
