# AI Financial Advisor — Environment Variables
# Copy this file to .env and fill in your values.

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: gemini | ollama
# - gemini: Calls Google Gemini 2.0 Flash API (requires GOOGLE_API_KEY below)
# - ollama: Calls a local Ollama model (requires Ollama daemon running)
MODEL_PROVIDER=gemini

# ── Google Gemini (used when MODEL_PROVIDER=gemini) ───────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here

# ── Ollama (used when MODEL_PROVIDER=ollama) ──────────────────────────────────
# Ensure Ollama is running: `ollama serve`
# Pull the model first:    `ollama pull qcwind/qwen2.5-7B-instruct-Q4_K_M:latest`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qcwind/qwen2.5-7B-instruct-Q4_K_M:latest
